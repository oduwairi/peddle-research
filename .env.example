# Draper.ai — API Keys
# Copy this file to .env and fill in your keys

# Ad intelligence
BIGSPY_API_KEY=
ADSPY_API_KEY=

# Web search
TAVILY_API_KEY=
EXA_API_KEY=
SERPER_API_KEY=

# Scraping
APIFY_API_TOKEN=
SERPAPI_API_KEY=

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# vLLM endpoint for the fine-tuned Draper model (config C in eval).
# Set after `modal deploy deploy/modal_vllm.py` — Modal prints the URL.
VLLM_BASE_URL=
VLLM_API_KEY=

# Training (cloud GPU runs only — leave empty for local-only work)
# Write-scope token from https://huggingface.co/settings/tokens
HF_TOKEN=
# Target HF model repo for adapter / merged-weights upload
HF_HUB_REPO=oduwairi/draper-qwen3-8b
# Pod SSH target (RunPod / Vast.ai give you these after you rent a pod)
POD_HOST=
POD_PORT=
# Optional: phone notifications via ntfy.sh — pick an unguessable topic name,
# subscribe at https://ntfy.sh/<topic> on your phone (no signup needed).
# Pings fire on smoke pass, train complete, errors, auto-shutdown.
NTFY_TOPIC=
# Optional: stop the pod automatically after a successful train+push so you
# don't pay for an idle GPU. Best-effort: prefers `runpodctl stop pod`,
# falls back to `shutdown -h now`.
AUTO_SHUTDOWN=
